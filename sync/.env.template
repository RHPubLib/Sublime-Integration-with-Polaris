# Gmail service account (SSRS reports are delivered here nightly)
# Create a dedicated service account in Google Workspace Admin.
# Enable 2-Step Verification, then generate an App Password at:
#   myaccount.google.com/apppasswords
GMAIL_ADDRESS=sublime-sync@yourlibrary.org
GMAIL_APP_PASSWORD=

# Sublime Security
# API key: Automate > API in the Sublime dashboard
# Base URL: shown next to your API key — regional subdomains vary
#   e.g. https://na-east-3.platform.sublime.security
SUBLIME_API_KEY=
SUBLIME_BASE_URL=https://platform.sublime.security

# Your staff email domain — addresses ending in this domain are excluded
# from all patron lists so staff never trigger patron banners.
STAFF_EMAIL_DOMAIN=yourlibrary.org

# SSRS subscription subject lines (must match exactly what each report subscription sends)
SSRS_SUBJECT_FULL=Sublime Full Patron Export
SSRS_SUBJECT_DIGITAL=Sublime Digital Patron Export
SSRS_SUBJECT_LIMITED=Sublime Limited Patron Export

# Sublime list IDs — leave blank to auto-discover by list name via API.
# You can hard-code these after the first run to skip the lookup.
SUBLIME_LIST_ID_FULL=
SUBLIME_LIST_ID_DIGITAL=
SUBLIME_LIST_ID_LIMITED=
